<html>
  <head>
    <title>Message Board</title>
  </head>
  <body>
    <%- include('navbar') %>
    <h2>Details for <span><%= message.username %>'s</span> message</h2>
    <p>Sent: <%= message.added.toLocaleString() %></p>
    <p><%= message.message %></p>
    <a href="/">Back</a>
  </body>
</html>
